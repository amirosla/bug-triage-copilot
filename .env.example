# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://triage:triage@localhost:5432/bug_triage

# ─── Redis / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── GitHub App ────────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/apps
GITHUB_APP_ID=123456
# Base64-encoded PEM private key: base64 -w0 your-key.pem
GITHUB_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTi...
# Secret set when creating the App's webhook
GITHUB_WEBHOOK_SECRET=supersecretwebhookkey

# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Options: "mock" (no API key needed) | "openai" (OpenAI-compatible endpoint)
LLM_PROVIDER=mock

# For OpenAI or compatible endpoints (Groq, Mistral, Ollama, etc.)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
